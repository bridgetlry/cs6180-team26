flowchart TB

    %% ================= DATA =================
    subgraph DATA["ACI-Bench Dataset"]
        direction LR
        CSV1[("Test1 Transcripts\n(40 encounters)")]
        CSV2[("Metadata\n(demographics · chief complaint)")]
        CSV1 --- CSV2
    end

    ENC["load_test1_encounters()\n→ 40 ACIEncounter objects\n(joined on encounter_id)"]

    %% ================= MODEL =================
    LLM["🧠 Llama-3.1-8B-Instruct\n(OpenRouter · T=0 · max_tokens=3000)\nShared across all techniques"]

    %% ================= TECHNIQUES =================
    subgraph TECHNIQUES["Structured Output Techniques"]
        direction LR

        BASIC["T0 · ACI-Bench Baseline\n───────────────\n• Reference condition\n• Original paper prompt\n• No schema · no validation\n• Single-shot (1 attempt)"]

        PE["T1 · Prompt Engineering\n───────────────\n• Constraint: Prompt-level\n• Single-shot (no retry)\n• JSON parse + Pydantic\n• Fail → stop (1 attempt)"]

        CD["T2 · Constrained Decoding\n───────────────\n• Constraint: Generation-time\n• Instructor · Mode.JSON\n• response_model=SOAPNote\n• Fail → exception (1 attempt)"]

        GVR["T3 · Generate-Validate-Retry\n───────────────\n• Constraint: Validation loop\n• Generate → Validate → Retry\n• Pydantic validation\n• Retry w/ failed_fields\n• Fail → up to 3 attempts"]

        BASIC --- PE --- CD --- GVR
    end

    %% ================= OUTPUTS =================
    subgraph OUT["Outputs"]
        direction LR
        PRED(["predictions.csv\nplain-text SOAP notes"])
        RES(["results.json\ntyped fields · failure info"])
    end

    %% ================= EVALUATION =================
    GOLD[("LLM as Judge · Team 26")]

    ROUGE["Text Quality Metrics\nROUGE-1 · ROUGE-2 · ROUGE-L · MEDCON"]

    TAXONOMY["Failure Taxonomy\n• Schema Violation\n• Missed Extraction\n• Hallucination\n• Unresolved Retry"]

    %% ================= FLOW =================
    DATA --> ENC --> LLM --> TECHNIQUES --> OUT

    PRED -- "evaluate_fullnote.py\nvs gold reference notes" --> ROUGE
    RES -- "typed fields + LLM as Judge
    " --> TAXONOMY
    GOLD --> TAXONOMY

