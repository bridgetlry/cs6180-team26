        Compact Schema
        always in sync with SOAPNote"]
        RULES["Extraction Rules
        + Reflection Checklist
        7 verification steps"]
    end

    LLM["🧠  LLM  ·  llama-3.1-8b-instruct  ·  T=0  ·  max_tokens=3000"]

    JSON["Layer 1 — parse_json_response()
    strip fences  ·  json.loads()  ·  brace repair"]

    JSON_GATE{"JSON valid?"}

    PYD["Layer 2 — SOAPNote(**parsed)
    5 required text fields  ·  44 total  ·  15 validators"]

    PYD_GATE{"Schema valid?"}

    RETRY["build_retry_prompt()
    transcript  ·  prev output  ·  exact failed_fields
    targeted error  ·  max 2 retries  ·  3 total calls"]

    SUCCESS(["✓ SUCCESS
    PipelineResult · success=True · attempts=1–3"])

    FAILURE(["✗ FAILURE
    failure_type: json_parse · pydantic · unexpected
    failed_fields · attempts=3"])

    INPUT --> EPF
    WS & SCHEMA & RULES --> LLM
    LLM -- "raw string" --> JSON
    JSON --> JSON_GATE
    JSON_GATE -- PASS --> PYD
    PYD --> PYD_GATE
    PYD_GATE -- PASS --> SUCCESS
    JSON_GATE -- "FAIL" --> RETRY
    PYD_GATE -- "FAIL + failed_fields" --> RETRY
    RETRY -. "retry with last_error" .-> LLM
    RETRY -- "attempts exhausted" --> FAILURE

